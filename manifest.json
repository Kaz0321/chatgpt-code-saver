{
  "manifest_version": 3,
  "name": "gpt-code-saver-extension",
  "version": "0.2.0",
  "description": "ChatGPTのコードブロックをローカルの拡張ソースに保存し、複数テンプレートを貼り付け・編集できるヘルパー。",
  "permissions": [
    "downloads",
    "downloads.open",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content/defaultTemplate.js",
        "content/state.js",
        "content/extensionToggle.js",
        "content/viewSettings.js",
        "content/saveOptions.js",
        "content/lightweightModeSettings.js",
        "shared/filePathValidation.js",
        "shared/projectFolderSettings.js",
        "shared/uiStyles.js",
        "content/toast.js",
        "content/reloadNotifier.js",
        "content/lightweightMode.js",
        "content/chatInput.js",
        "content/templateStore.js",
        "content/templateEditor.js",
        "content/logModal.js",
        "content/chatLogTracker.js",
        "content/chatLogModalActions.js",
        "content/chatLogModalFormatting.js",
        "content/chatLogModal.js",
        "content/panelVisibility.js",
        "content/panelComponents.js",
        "content/panelProjectFolder.js",
        "content/panelSaveOptions.js",
        "content/panelTemplates.js",
        "content/panelLightweightMode.js",
        "content/panelViewSection.js",
        "content/panelLogSection.js",
        "content/panelExtensionToggle.js",
        "content/panel.js",
        "content/codeBlockMetadata.js",
        "content/codeBlockViewMode.js",
        "content/codeBlockButtons.js",
        "content/codeBlocks.js",
        "content/init.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
