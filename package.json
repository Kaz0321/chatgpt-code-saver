{
  "name": "chatgpt-code-saver",
  "version": "0.4.4",
  "private": true,
  "description": "MV3 workspace for ChatGPT Code Saver with unit tests and Playwright smoke coverage",
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:benchmark:lightweight": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js tests/e2e/lightweight-benchmark.spec.js",
    "test:e2e": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js",
    "test:e2e:headed": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js --headed",
    "test:e2e:full": "node tests/tools/run-playwright.js test --config tests/playwright.full.config.js",
    "test:e2e:ui": "node tests/tools/run-playwright.js test --config tests/playwright.ui.config.js",
    "test:e2e:live": "node tests/tools/run-playwright.js test --config tests/playwright.live.config.js",
    "collect:headings": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/collect-chatgpt-headings-anonymous.js",
    "collect:headings:anonymous": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/collect-chatgpt-headings-anonymous.js",
    "collect:ui-patterns:x11": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/collect-chatgpt-ui-patterns-x11.js",
    "sync:ui-pattern-fixtures": "node tests/tools/sync-chatgpt-ui-pattern-fixtures.js",
    "verify:offline-frame": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/verify-offline-frame-requirements.js",
    "test:e2e:ui-pattern-evidence": "node tests/tools/run-ui-pattern-evidence.js",
    "capture:ui-pattern-evidence:x11": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/capture-ui-pattern-evidence-x11.js",
    "test:e2e:heading-fixtures": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js tests/e2e/heading-variations-offline.spec.js",
    "test:e2e:ui-pattern-fixtures": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js tests/e2e/chatgpt-ui-patterns-offline.spec.js",
    "test:e2e:ui-pattern-extension-fixtures": "node tests/tools/run-playwright.js test --config tests/playwright.regression.config.js tests/e2e/chatgpt-ui-patterns-extension-offline.spec.js",
    "fetch:share-assets": "node tests/tools/fetch-chatgpt-share-assets.js",
    "open:chatgpt:gpu": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/open-chatgpt-gpu.js",
    "open:chatgpt:x11-ime": "LD_LIBRARY_PATH=\"$PWD/tests/.local-libs/usr/lib/x86_64-linux-gnu\" node tests/tools/open-chatgpt-x11-ime.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "standard-version": "^9.5.0"
  }
}
