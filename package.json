{
  "name": "gpt-code-saver-extension",
  "version": "0.2.4",
  "private": true,
  "description": "MV3 workspace for gpt-code-saver-extension with unit tests and Playwright smoke coverage",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "LD_LIBRARY_PATH=\"$PWD/.local-libs/usr/lib/x86_64-linux-gnu\" playwright test",
    "test:e2e:headed": "LD_LIBRARY_PATH=\"$PWD/.local-libs/usr/lib/x86_64-linux-gnu\" playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "standard-version": "^9.5.0"
  }
}
